              "mode": "raw",
              "raw": "{\n  \"email\": \"your-email@example.com\",\n  \"password\": \"MD5_UPPERCASE_HASH_HERE_OR_CLEARTEXT\",\n  \"appVersion\": \"1.1.0\",\n  \"appName\": \"Hookii App\",\n  \"phoneModel\": \"Android\",\n  \"osVersion\": \"16\"\n}\n"
            },
            "url": {
              "raw": "https://iot.hookii.com:10443/api/v1/user/login/email",
              "protocol": "https",
              "host": [
                "iot",
                "hookii",
                "com"
              ],
              "port": "10443",
              "path": [
                "api",
                "v1",
                "user",
                "login",
                "email"
              ]
            },
            "description": "Login to Hookii Production cloud with your account credentials. Returns JWT token needed for subsequent requests. Save the JWT and use it in other requests."
